# 招聘助手配置文件
# 复制此文件为 .env 并填入实际值

# AI 功能（可选）
AI_ENABLED=false
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# 邮件发送 SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

# 邮件接收 IMAP
IMAP_HOST=
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=

# 飞书
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 腾讯会议账号池 - 逗号分隔的标签
# 每个标签对应 data/meeting_browser_{label}/ 的独立登录态
# 同一时段多场面试会自动分配到不同账号主持
# 首次用新标签时会打开浏览器等你扫码登录（120 秒）
TENCENT_MEETING_ACCOUNTS=main,backup


# Boss 直聘
BOSS_ADAPTER=edge_extension
BOSS_MAX_OPERATIONS_PER_HOUR=30
BOSS_MAX_OPERATIONS_PER_DAY=200

# ===== AI 辅助面试评估 (F-interview-eval) =====
INTERVIEW_EVAL_ENABLED=false
TENCENT_CLOUD_SECRET_ID=
TENCENT_CLOUD_SECRET_KEY=
TENCENT_CLOUD_ASR_REGION=ap-shanghai
INTERVIEW_EVAL_RECORDING_RETENTION_DAYS=180
